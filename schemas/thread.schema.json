{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/alexanderhorn6720/rdm-discussion/schemas/thread.schema.json",
  "title": "rdm-discussion thread frontmatter",
  "description": "Frontmatter shape enforced by scripts/validate-threads.mjs. Applies to threads >= 175 (grandfathering). Older threads are reported as advisories only.",
  "soft_mode": true,
  "soft_mode_expires": "2026-05-29",
  "type": "object",
  "required": ["thread", "author", "date", "topic", "mode", "status"],
  "properties": {
    "thread": {
      "type": "integer",
      "minimum": 1,
      "description": "Sequential number claimed via scripts/new-thread.sh."
    },
    "author": {
      "type": "string",
      "enum": [
        "WC",
        "WC-Platform",
        "WC-Impl",
        "CC",
        "CC-Bot",
        "CC-Data",
        "CC-Pago",
        "CC-Web",
        "Alex"
      ]
    },
    "date": {
      "type": "string",
      "format": "date",
      "description": "YYYY-MM-DD (UTC)."
    },
    "topic": {
      "type": "string",
      "minLength": 5
    },
    "mode": {
      "type": "string",
      "enum": [
        "brain",
        "brain quick",
        "brain deep",
        "brain ultra",
        "DoIt",
        "verify",
        "challenge response",
        "synthesis"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "open",
        "response",
        "halt",
        "closed",
        "abandoned",
        "open-for-alex-vote",
        "ready-for-cc-execution",
        "open-for-challenge"
      ]
    },
    "related": {
      "type": "array",
      "items": { "type": "string" }
    },
    "deliverable": {
      "type": "string"
    },
    "daily_cost_budget_usd": {
      "type": ["integer", "null"],
      "minimum": 1,
      "maximum": 500,
      "description": "Per-thread budget override for T5 cost-limit hook. If absent, env DAILY_COST_BUDGET_USD applies. Recommended tiers: 20 (exploration), 100 (doit_normal), 200 (doit_multi_cc). Post Max plan: warning-only, no hard halt."
    },
    "halt_global_budget_usd": {
      "type": ["number", "null"],
      "minimum": 1,
      "description": "Absolute spend ceiling for this thread execution. CC must halt if exceeded, regardless of plan mode."
    }
  },
  "additionalProperties": true
}
