# Local worktrees used by parallel CC sessions (created via `git worktree add`).
# These hold transient branches and should never appear as tracked files in main.
.worktree-*/

# Audit scratch space outputs — ignore generated result files but track scripts + README
reports/.audit-scratch/results/

# PDFs — keep out of git (thread/182 G6). Exceptions in archive/ are OK.
*.pdf
!archive/**/*.pdf
